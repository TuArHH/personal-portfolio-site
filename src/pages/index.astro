---
import Main from '../layouts/Main.astro'
import TechCard from '../components/TechCard.astro'
import profilePicture from '../img/TugrulArslan.webp'

import Azure       from '../components/Technology/Azure.astro'
import CSharp      from '../components/Technology/CSharp.astro'
import SQL         from '../components/Technology/SQL.astro'
import Git         from '../components/Technology/Git.astro'
import Powershell  from '../components/Technology/Powershell.astro'
import Linux       from '../components/Technology/Linux.astro'
import PowerBI     from '../components/Technology/PowerBI.astro'
import Figma       from '../components/Technology/Figma.astro'
import Python      from '../components/Technology/Python.astro'
import Spark       from '../components/Technology/Spark.astro'
import Databricks  from '../components/Technology/Databricks.astro'
import Snowflake   from '../components/Technology/Snowflake.astro'
import IaC         from '../components/Technology/IaC.astro'

const jobs = [
  {
    company:  'Helm AG',
    location: 'Hamburg, Germany',
    period:   'Jan 2025 – Present',
    title:    'Azure Cloud Data Engineer',
    bullets: [
      'Design and develop scalable data pipelines ingesting data from multiple sources into the Data Lake',
      'Automate CI/CD workflows for data infrastructure deployments',
      'Core stack: Azure Data Factory, Databricks, Data Lake Storage, virtual machines, REST API integrations, Data Vault 2.0 modelling and Snowflake',
    ],
  },
  {
    company:  'Donner & Reuschel',
    location: 'Hamburg, Germany',
    period:   'Jan 2024 – Jan 2025',
    title:    'Senior Data Engineer',
    bullets: [
      'Implemented and evolved ETL pipelines using Azure Data Factory',
      'Integrated load files in CSV and XML formats into the data warehouse',
    ],
  },
  {
    company:  'Eurofins GmbH',
    location: 'Hamburg, Germany',
    period:   'Sept 2020 – Apr 2023',
    title:    'Senior Business Intelligence Developer',
    bullets: [
      'Led design and implementation of ETL processes using Microsoft SQL Server',
      'Reduced pipeline load times to under three minutes in real time',
      'Built reports and dashboards with Power BI and Microsoft Report Server',
      'Developed a REST API–based application to monitor and track internal services',
    ],
  },
  {
    company:  'ITGAIN GmbH',
    location: 'Cologne, Germany',
    period:   'Jan 2019 – Jul 2020',
    title:    'IT Consultant',
    bullets: [
      'Built and optimised ETL pipelines using IBM DataStage',
      'Administered Linux environments to ensure stable data infrastructure',
      'Optimised SQL statements in Oracle to maximise query performance',
    ],
  },
]
---

<Main>
  <!-- ── About ──────────────────────────────────────────── -->
  <section id="about" class="section">
    <div class="container hero">
      <img
        src={profilePicture.src}
        alt="Tugrul Arslan"
        width="160"
        height="160"
        class="avatar"
      />
      <div class="hero-text">
        <p class="section-title">Hello, I'm</p>
        <h1>Tugrul Arslan</h1>
        <h2>Cloud Data Engineer</h2>
        <p class="bio">
          I design and build scalable data pipelines and cloud-native architectures on Azure.
          My work spans the full data stack — from infrastructure as code and ETL pipelines
          to data warehousing and interactive dashboards. I'm passionate about transforming
          raw, messy data into reliable, actionable insights.
        </p>
        <div class="tags">
          <span class="tag">Azure</span>
          <span class="tag">Data Engineering</span>
          <span class="tag">Cloud Architecture</span>
          <span class="tag">ETL</span>
        </div>
      </div>
    </div>
  </section>

  <div class="container"><div class="divider"></div></div>

  <!-- ── Experience ─────────────────────────────────────── -->
  <section id="experience" class="section">
    <div class="container">
      <p class="section-title">Where I've worked</p>
      <h3 class="section-heading">Experience</h3>

      <div class="timeline">
        {jobs.map((job) => (
          <div class="job">
            <div class="job-meta">
              <span class="job-period">{job.period}</span>
              <span class="job-location">{job.location}</span>
            </div>
            <div class="job-body">
              <div class="job-header">
                <h4 class="job-title">{job.title}</h4>
                <span class="job-company">{job.company}</span>
              </div>
              <ul class="job-bullets">
                {job.bullets.map((b) => <li>{b}</li>)}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="container"><div class="divider"></div></div>

  <!-- ── Technologies ───────────────────────────────────── -->
  <section id="technologies" class="section">
    <div class="container">
      <p class="section-title">What I work with</p>
      <h3 class="section-heading">Technologies</h3>
      <div class="tech-grid">
        <TechCard name="Azure">        <Azure />       </TechCard>
        <TechCard name="Python">       <Python />      </TechCard>
        <TechCard name="Apache Spark"> <Spark />       </TechCard>
        <TechCard name="Databricks">   <Databricks />  </TechCard>
        <TechCard name="Snowflake">    <Snowflake />   </TechCard>
        <TechCard name="Terraform">    <IaC />         </TechCard>
        <TechCard name="SQL">          <SQL />         </TechCard>
        <TechCard name="Git">          <Git />         </TechCard>
        <TechCard name="PowerShell">   <Powershell />  </TechCard>
        <TechCard name="Linux">        <Linux />       </TechCard>
        <TechCard name="Power BI">     <PowerBI />     </TechCard>
        <TechCard name="C#">           <CSharp />      </TechCard>
        <TechCard name="Figma">        <Figma />       </TechCard>
      </div>
    </div>
  </section>
</Main>

<style>
  /* ── Hero ──────────────────────────────────────────────── */
  .hero {
    display: flex;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .avatar {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    object-position: 35% 28%;
    flex-shrink: 0;
    border: 4px solid var(--accent);
    box-shadow: 0 0 0 8px color-mix(in srgb, var(--accent) 15%, transparent);
  }

  .hero-text { flex: 1; min-width: 260px; }
  .hero-text h1 { margin: 0.2rem 0 0.3rem; color: var(--text); }
  .hero-text h2 { margin-bottom: 1.1rem; }

  .bio {
    max-width: 540px;
    margin-bottom: 1.5rem;
    font-size: 0.97rem;
  }

  .tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }

  .tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    letter-spacing: 0.02em;
  }

  /* ── Timeline ──────────────────────────────────────────── */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .job {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 1.5rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
  }

  .job:last-child { border-bottom: none; }

  .job-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: 0.15rem;
  }

  .job-period {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent);
    white-space: nowrap;
  }

  .job-location {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .job-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .job-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
  }

  .job-company {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  .job-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .job-bullets li {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
    padding-left: 1.1rem;
    position: relative;
  }

  .job-bullets li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.75rem;
    top: 0.15rem;
  }

  /* ── Tech grid ─────────────────────────────────────────── */
  .tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 1rem;
  }

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 600px) {
    .hero { gap: 1.5rem; }
    .avatar { width: 120px; height: 120px; }

    .job {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }

    .job-meta { flex-direction: row; gap: 0.75rem; flex-wrap: wrap; }
  }
</style>
