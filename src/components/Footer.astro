---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <span>© {year} Tugrul Arslan</span>
    <span class="footer-sub">Cloud Data Engineer</span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background: var(--bg-alt);
    padding: 1.25rem 0;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .footer-sub {
    opacity: 0.7;
  }
</style>
